// LeetCode -> 2220. Minimum Bit Flips to Convert Number
class Solution {
public:
    int minBitFlips(int start, int goal) {
        int count =0;
        while(start || goal){
            int l1 = start&1;
            int l2 = goal&1;
            if(l1 != l2) count++;
            start >>=1;
            goal >>= 1;
        }
        return count;
    }
};
