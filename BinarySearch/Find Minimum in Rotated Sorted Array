// LeetCode -> Find Minimum in Rotated Sorted Array
class Solution {
public:
int findPivot(vector<int>&nums){
    int s = 0;
    int e =nums.size()-1;
    while(s<e){
        int mid=s+(e-s)/2;
        if(nums[mid] <= nums[e]){
            e = mid;
        }
        else{
            s = mid+1;
        }
    }
    return s;
}
    int findMin(vector<int>& nums) {
        int mini = findPivot(nums);
        return nums[mini];
    }
};
