// LeetCode -> 141. Linked List Cycle
class Solution {
public:
    bool hasCycle(ListNode *head) {
        ListNode* slow = head;
        ListNode* fast = head;
        if(head == NULL)return false;
        while(fast -> next != NULL && fast -> next->next != NULL){
            fast = fast ->next -> next;
            slow = slow->next;
            if(slow == fast) return true;
        }
        return false;
    }
};
