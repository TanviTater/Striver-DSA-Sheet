// LeetCode -> 19. Remove Nth Node From End of List
class Solution {
public:
    ListNode* removeNthFromEnd(ListNode* head, int n) {
        if(head == NULL) return NULL;
        if(head -> next == NULL) return NULL;
        ListNode* temp = head;
        int len = 0;
        while(temp != NULL){
            len++;
            temp = temp -> next;
        }
        int desPos = len-n;
        int count = 0;
        temp = head;
        if(desPos == 0){
            temp  = temp->next;
            return temp;
        }
        else{
            while(count!=desPos-1){
                count++;
                temp =temp->next;
            }
            temp -> next = temp -> next ->next;
        }
        
        
        return head;
    }
};
