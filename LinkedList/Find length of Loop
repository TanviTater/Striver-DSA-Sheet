// GeeksForGeeks -> Find length of Loop
class Solution {
  public:
    int lengthOfLoop(Node *head) {
        
        if(head == NULL) return 0;
        Node* temp = head;
        Node* fast = head;
        Node* slow = head;
        
        while(fast->next != NULL && fast ->next ->next != NULL){
            fast = fast->next->next;
            slow = slow->next;
            if(slow == fast){
                int llLength = 1;
                fast = fast -> next;
                while(slow != fast){
                    llLength+=1;
                    fast = fast-> next;
                }
                return llLength;
            }
        }
        return 0;
    }
};
