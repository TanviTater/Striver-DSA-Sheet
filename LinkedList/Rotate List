// LeetCode -> 61. Rotate List
class Solution {
public:
    ListNode* rotateRight(ListNode* head, int k) {
        if(head == NULL || head -> next == NULL) return head;
        ListNode* temp = head;
        int n =1;
        while(temp -> next!= NULL){
            temp = temp->next;
            n++;
        }
        temp -> next = head;
        k = k%n;
        int steps = n-k;
        int count =0;
        while(count != steps){
            temp =temp->next;
            count++;
        }
        ListNode* newHead = temp -> next;
        temp->next = NULL;
        return newHead;
    }
};
