// LeetCode -> 234. Palindrome Linked List
class Solution {
public:
ListNode* reverse(ListNode* head){
    ListNode* curr = head;
    ListNode* prev = NULL;
    ListNode* next = NULL;
    while(curr != NULL){
        next = curr -> next;
        curr -> next = prev;
        prev = curr;
        curr = next;
    }
    return prev;
}
    bool isPalindrome(ListNode* head) {
        if(head == NULL || head -> next == NULL){
            return true;
        }
        ListNode* fast = head;
        ListNode* slow = head;
        while(fast -> next != NULL && fast -> next -> next != NULL){
            fast = fast -> next-> next;
            slow = slow -> next;
        }
        ListNode* rev = reverse(slow->next);
        while(head != NULL && rev != NULL){
            if(head ->val != rev -> val) return false;
            head = head -> next;
            rev = rev -> next;
        }
        return true;
    }
};
