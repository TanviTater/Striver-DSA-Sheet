// GeeksForGeeks -> Array Leaders
class Solution {
  public:
    vector<int> leaders(vector<int>& arr) {
        int maxi = INT_MIN;
        vector<int>ans;
        for(int i =arr.size()-1;i>=0;i--){
            if(arr[i] >= maxi){
                maxi = arr[i];
                ans.push_back(arr[i]);
            }
        }
        reverse(ans.begin(),ans.end());
        return ans;
    }
};
