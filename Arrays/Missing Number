//Leetcode -> 268. Missing Number
class Solution {
public:
    int missingNumber(vector<int>& nums) {
        int n = nums.size();
        int sum = (n*(n+1))/2;
        int actualSum =0;
        int missing = 0;
        for(int i = 0;i<nums.size();i++){
            actualSum += nums[i];
        }
        cout<<sum<<" "<<actualSum<<endl;
        missing = sum-actualSum;
        return missing;
    }
};
