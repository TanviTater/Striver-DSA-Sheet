// Leectcode -> 1. Two Sum
class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map<int,int>mp;
        for(int i =0;i<nums.size();i++){
            int x = nums[i];
            int toFind = target - x;
            if(mp.contains(toFind)){
                return {mp[toFind],i};
            }
            mp[x] = i;
        }
        return {-1};
    }
};
