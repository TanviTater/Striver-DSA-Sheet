// leetcode -> 1752 Check if Array Is Sorted and Rotated
class Solution {
public:
    bool check(vector<int>& arr) {
        int count = 0;
        int n = arr.size();

        for (int i = 1; i < n; i++) {
            if (arr[i] < arr[i - 1]) {
                count++;
            }
        }

        if (arr[n - 1] > arr[0]) {
            count++;
        }

        return count <= 1;
    }
};
