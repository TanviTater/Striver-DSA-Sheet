// LeetCode -> 1848. Minimum Distance to the Target Element
class Solution {
public:
    int getMinDistance(vector<int>& nums, int target, int start) {
        int diff = INT_MAX;
        for(int i =0;i<nums.size();i++){
            if(nums[i] == target){
                int temp = abs(i-start);
                diff = min(diff,temp);
            }
        }
        return diff;
    }
};
