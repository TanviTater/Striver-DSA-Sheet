// LeetCode -> 39. Combination Sum
class Solution {
public:
void solve(int i,vector<int>& nums,vector<int>&temp,vector<vector<int>>& ans,int target,int sum){
    if(sum == target){
        ans.push_back(temp);
        return;
    }
    if(sum>target) return;
    if(i>=nums.size())return;
    temp.push_back(nums[i]);
    solve(i,nums,temp,ans,target,sum+nums[i]);
    temp.pop_back();
    solve(i+1,nums,temp,ans,target,sum);
}
    vector<vector<int>> combinationSum(vector<int>& candidates, int target) {
        vector<int>temp;
        vector<vector<int>>ans;
        solve(0,candidates,temp,ans,target,0);
        return ans;
    }
};
