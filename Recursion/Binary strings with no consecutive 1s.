// CodingNinjas =>  Binary strings with no consecutive 1s.
void solve(int i,string& s,vector<string>&ans){
    if(i>=s.size()){
        ans.push_back(s);
        return;
    }
    solve(i+1,s,ans);
    s[i] = '1';
    solve(i+2,s,ans);
    s[i] ='0';
}
vector<string> generateString(int N) {
    string temp(N,'0');
    vector<string>ans;
    solve(0,temp,ans);
    return ans;
}
