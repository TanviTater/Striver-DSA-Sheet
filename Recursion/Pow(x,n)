// LeetCode -> 50. Pow(x, n)
class Solution {
public:
double solve(double x,int n){
    if(n == 0) return 1;
    if(n == 1) return x;
    double ans = solve(x,n/2);
    if(n%2 == 0){
        return ans*ans;
    }
    return x*ans*ans;
}

    double myPow(double x, int n) {
        long long nn = n;
        if(nn < 0){
            nn = -nn;
            x = 1/x;
        }
        return solve(x,nn);
    }
};
