// LeetCode -> 1903. Largest Odd Number in String
class Solution {
public:
    string largestOddNumber(string num) {
        int j = num.size()-1;
        while(j>=0){
            if(num[j]%2!=0){
                break;
            }
            j--;
        }
        string ans;
        for(int i =0;i<=j;i++){
            ans.push_back(num[i]);
        }
        return ans;
    }
};
