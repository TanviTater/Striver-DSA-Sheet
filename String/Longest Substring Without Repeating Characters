// LeetCode -> 3. Longest Substring Without Repeating Characters
class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        int maxLen = 0;
        unordered_map<char,int>count;
        int j =0;
        for(int i=0;i<s.size();i++){
            count[s[i]]++;
            while(count[s[i]]>1){
                count[s[j]]--;
                j++;
            }
            maxLen = max(maxLen,i-j+1);
        }
        return maxLen;
    }
};
