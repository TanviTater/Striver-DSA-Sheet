// LeetCode -> 125. Valid Palindrome
class Solution {
public:
void toLower(char ch,string &s){
    if(ch >= 'a' && ch <= 'z'){
        s.push_back(ch);
    }
    else if(ch >= 'A' && ch <= 'Z'){
        char ele = ch -'A'+'a';
        s.push_back(ele);
    }
    else if(ch >= '0' && ch <= '9'){
        s.push_back(ch);
    }
}
    bool isPalindrome(string s) {
        string newS ="";
        for(int i =0;i<s.size();i++){
            toLower(s[i],newS);
        }
        int i = 0;
        int j = newS.size()-1;
        while(i<=j){
            if(newS[i] != newS[j]) return false;
            i++;
            j--;
        }
        return true;
    }
};
